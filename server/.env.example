# Application
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/rideflow

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=replace_with_a_strong_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Google Maps (Distance Matrix API enabled)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Fare calculation (USD)
BASE_FARE=2.50
PER_KM_RATE=1.20
PER_MINUTE_RATE=0.25
SURGE_MULTIPLIER=1.5
RUSH_HOUR_START=7
RUSH_HOUR_END=9

# Driver matching
DRIVER_SEARCH_RADIUS_METERS=5000
DRIVER_OFFER_COUNT=3
TRIP_REQUEST_TIMEOUT_MS=30000
LOCATION_UPDATE_INTERVAL_MS=5000
